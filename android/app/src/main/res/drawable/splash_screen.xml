<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark backdrop matches the card's frame so the artwork sits cleanly. -->
    <item android:drawable="@android:color/black" />
    <!-- Card centred and constrained to a portrait-friendly box. -->
    <item
        android:gravity="center"
        android:width="340dp"
        android:height="210dp">
        <bitmap android:src="@drawable/rishi22_splash" />
    </item>
</layer-list>
